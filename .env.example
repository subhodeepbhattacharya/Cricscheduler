# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Google Maps — enable Places API at https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# UPI merchant details (MVP: hardcoded host VPA)
NEXT_PUBLIC_UPI_MERCHANT_VPA=yourname@upi
NEXT_PUBLIC_APP_NAME=CricScheduler

# Google reCAPTCHA v3 — create keys at https://www.google.com/recaptcha/admin/create
# Choose "reCAPTCHA v3", add your domain(s) (include localhost for dev).
# If these are unset, captcha checks are skipped (so local dev still works).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-v3-secret-key
# Minimum score (0.0–1.0) to accept; 0.5 is Google's recommended default.
RECAPTCHA_MIN_SCORE=0.5

# --- MSG91 WhatsApp OTP delivery (Supabase Edge Function secrets, NOT Next.js env) ---
# The Supabase "Send SMS Hook" fires on phone OTP; our Edge Function delivers the
# code over WhatsApp via MSG91 (no Indian DLT/SMS registration required).
#
# Set these in Supabase Dashboard → Edge Functions → sms-hook → Secrets,
# and enable Auth → Hooks → Send SMS → HTTPS:
#   https://<project-ref>.supabase.co/functions/v1/sms-hook
#
# SEND_SMS_HOOK_SECRET       — from Auth → Hooks → Send SMS (includes v1,whsec_ prefix)
# MSG91_AUTHKEY              — MSG91 dashboard auth key
# MSG91_WA_INTEGRATED_NUMBER — your MSG91-registered WhatsApp Business number (digits, w/ country code)
# MSG91_WA_TEMPLATE_NAME     — approved WhatsApp authentication template name
# MSG91_WA_TEMPLATE_LANG     — optional; template language code (default: en_US)
# MSG91_WA_NAMESPACE         — optional; template namespace if your account requires it
# MSG91_WA_INCLUDE_BUTTON    — optional; "false" to omit the copy-code button (default: true)
# MSG91_WA_ENDPOINT          — optional; override MSG91 WhatsApp API URL if needed
#
# Deploy: npx supabase functions deploy sms-hook --no-verify-jwt
